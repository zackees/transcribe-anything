# Copy to .env (gitignored) and fill in your values, then:
#   set -a; source runpod/.env; set +a

# === RunPod credentials — required by client_example.py ===
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# === HuggingFace token — required for speaker.json diarization ===
# Generate at https://huggingface.co/settings/tokens (simple "Read" type works).
# Also accept agreements at:
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# === Resolver host config — only needed if you use the --resolve flag ===
# The --resolve flag pipes the input URL through a residential-IP host before
# RunPod, so YouTube / Spotify / listennotes / paywalled sources work
# (datacenter IPs get blocked by those services).
#
# Set TRANSCRIBE_RESOLVER_HOST to your residential-IP machine's SSH target
# (e.g. you@home-server.tail-xxxx.ts.net), and TRANSCRIBE_RESOLVER_SCRIPT
# to the absolute path of runpod/resolve_and_host.py on that machine.
# The resolver host itself needs AUDIO_* env vars set — see resolve_and_host.py
# docstring.
TRANSCRIBE_RESOLVER_HOST=
TRANSCRIBE_RESOLVER_SCRIPT=
