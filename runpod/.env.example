# Copy to .env (gitignored) and fill in your values.

# RunPod credentials — used by client_example.py
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Hugging Face token — only needed if you want speaker.json (diarization).
# Get one at https://huggingface.co/settings/tokens and accept the user
# agreement at https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=
